# Optional: live generation for any ambiguous Tamil word
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Alternative
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Judge / offline: set to 1, true, yes, or on — skips all OpenAI & Gemini calls in generatePipelineAsync
# DISABLE_LLM=1
# LEXIFYD_OFFLINE=1

# Submission / no cloud APIs: local Tamil WordNet bundle only (lib/wordnet/lexicon.json + curated seeds in lib/seed.ts)
# LEXIFYD_NO_REMOTE_API=1
